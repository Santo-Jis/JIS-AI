# ─── JIS-AI Environment Variables ───────────────────────────
# Railway Dashboard → Variables এ এগুলো দিন

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# WhatsApp (Meta — ঐচ্ছিক, Baileys থাকলে লাগবে না)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=my_secret_verify_token

# Baileys Gateway
BAILEYS_URL=http://localhost:3001        # একই server এ, তাই localhost
BAILEYS_PORT=3001
AUTH_FOLDER=/data/baileys_auth           # Railway persistent disk

# Security — NovaTech BD এর সাথে match করতে হবে
API_SECRET=your-strong-secret-key-here

# App
SECRET_KEY=your-app-secret-key
DEBUG=false
PORT=8000
